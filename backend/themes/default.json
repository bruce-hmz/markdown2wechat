{
  "name": "默认主题",
  "version": "1.0",
  "styles": {
    "global": {
      "font-family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      "font-size": "16px",
      "line-height": "1.75",
      "color": "#333333",
      "text-align": "justify",
      "word-wrap": "break-word"
    },
    "heading": {
      "h1": {
        "font-size": "24px",
        "font-weight": "bold",
        "margin": "25px 0 15px",
        "text-align": "center",
        "color": "#000000"
      },
      "h2": {
        "font-size": "20px",
        "font-weight": "bold",
        "margin": "20px 0 10px",
        "color": "#000000"
      },
      "h3": {
        "font-size": "18px",
        "font-weight": "bold",
        "margin": "18px 0 8px",
        "color": "#000000"
      },
      "h4": {
        "font-size": "16px",
        "font-weight": "bold",
        "margin": "15px 0 5px",
        "color": "#000000"
      }
    },
    "code": {
      "block": {
        "border": "1px solid #e0e0e0",
        "color": "#333333",
        "padding": "15px",
        "border-radius": "5px",
        "overflow-x": "auto",
        "font-family": "Consolas, Monaco, 'Courier New', monospace",
        "font-size": "14px",
        "line-height": "1.5"
      },
      "inline": {
        "color": "#c7254e",
        "padding": "2px 6px",
        "font-family": "Consolas, Monaco, 'Courier New', monospace",
        "font-size": "14px"
      }
    },
    "blockquote": {
      "border-left": "4px solid #e0e0e0",
      "padding": "10px 20px",
      "margin": "20px 0",
      "color": "#666666",
      "font-style": "italic"
    },
    "list": {
      "margin": "15px 0",
      "padding-left": "30px"
    },
    "link": {
      "color": "#3b82f6",
      "text-decoration": "underline"
    },
    "image": {
      "max-width": "100%",
      "height": "auto",
      "display": "block",
      "margin": "20px auto",
      "border-radius": "4px"
    },
    "table": {
      "table": {
        "width": "100%",
        "border-collapse": "collapse",
        "margin": "20px 0",
        "font-size": "14px"
      },
      "th": {
        "padding": "10px",
        "border": "1px solid #ddd",
        "font-weight": "bold",
        "text-align": "left"
      },
      "td": {
        "padding": "10px",
        "border": "1px solid #ddd"
      }
    }
  }
}
