{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/main"
    },
    {
      "source": "/api/",
      "destination": "/api/main"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
